{
  "description": "pantheon: prompt router (auto-fires the right discipline) + learning capture (logs each turn's user signal for consolidation).",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT\"/hooks/route.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT\"/hooks/capture-learning.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
